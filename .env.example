# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/ibm-immobiliere

# Public app URL (used in metadata + share images)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Analytics 4 (optional). Format: G-XXXXXXXXXX — from GA4 Admin → Data streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GA_DISABLED=false

# Google Search Console HTML tag verification (optional). Paste the content value only
# (Search Console → Add property → HTML tag → copy content="…")
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Meta Pixel + Conversions API (optional)
NEXT_PUBLIC_META_PIXEL_ID=
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v25.0
META_TEST_EVENT_CODE=
NEXT_PUBLIC_META_TRACKING_DISABLED=false
META_TRACKING_DISABLED=false

# Admin authentication
# Use ADMIN_PASSWORD_HASH (bcrypt) in production. ADMIN_PASSWORD is dev-only.
ADMIN_EMAIL=admin@ibm-immobiliere.tn
ADMIN_NAME=Administrateur
ADMIN_PASSWORD=admin
# ADMIN_PASSWORD_HASH=$2a$10$...

# Iron-session encryption key (≥32 chars). Generate with: openssl rand -base64 48
SESSION_PASSWORD=replace-with-32+-character-random-secret-please

# OVH Mail SMTP. Create the mailbox in OVHcloud, then use its full address here.
OVH_SMTP_HOST=ssl0.ovh.net
OVH_SMTP_PORT=465
OVH_SMTP_USER=contact@ibm-immobiliere.tn
OVH_SMTP_PASSWORD=
OVH_SMTP_FROM="IBM Immobilière <contact@ibm-immobiliere.tn>"
LEAD_NOTIFICATION_EMAIL=contact@ibm-immobiliere.tn

# Mandatory legal identity and hosting details displayed on /mentions-legales
NEXT_PUBLIC_LEGAL_FORM=
NEXT_PUBLIC_RNE_NUMBER=
NEXT_PUBLIC_TAX_ID=
NEXT_PUBLIC_HOST_NAME=OVHcloud
NEXT_PUBLIC_HOST_ADDRESS=2 rue Kellermann, 59100 Roubaix, France
